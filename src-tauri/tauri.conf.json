{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Genta",
  "version": "1.1.0",
  "identifier": "com.mafiefa.genta",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Genta - Aplikasi Bel",
        "width": 820,
        "height": 680,
        "minWidth": 820,
        "minHeight": 680,
        "maxWidth": 1000,
        "maxHeight": 1080
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../public/default_bell.mp3": "default_bell.mp3"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE0OUZBRTRCRTI3REE1OEIKUldTTHBYM2lTNjZmcFB6VjB4d2czQnVsbHlZSEY2ZWJjRktUcGtzUnZrUGgvRzZWM2t5T0dxZGkK",
      "endpoints": ["https://github.com/mafiefa02/kron/releases/latest/download/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    },
    "sql": {
      "preload": ["sqlite:genta.db"]
    }
  }
}
