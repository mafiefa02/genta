{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "genta",
  "version": "1.0.0",
  "identifier": "com.mafiefa.genta",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Genta - Aplikasi Bel",
        "width": 800,
        "height": 800,
        "minWidth": 680,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZEOUUwNjNEMTNFQzg1QjYKUldTMmhld1RQUWFlYlM3UDdUS0NtRlkxYk5KOXZiL25TeGNVTGZRVTlwUXdLS280UXpkTzlyQ2cK",
      "endpoints": ["https://github.com/mafiefa02/kron/releases/latest/download/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    },
    "sql": {
      "preload": ["sqlite:genta.db"]
    }
  }
}
